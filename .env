import os
import mysql.connector
from werkzeug.security import generate_password_hash
from dotenv import load_dotenv

# Cargar las variables de tu archivo .env
load_dotenv()

try:
    conexion = mysql.connector.connect(
        host=os.getenv("DB_HOST", "localhost"),
        user=os.getenv("DB_USER", "root"),
        password=os.getenv("DB_PASSWORD", ""),
        database=os.getenv("DB_NAME", "mitiendaweb_db")
    )
    
    cursor = conexion.cursor()

    # El correo que ya existe y queremos convertir en admin
    correo_admin = "admin@gmail.com"
    contrasena_plana = "Admin123!" # La nueva contraseña que quieres asignarle
    rol_usuario = "admin"

    # Encriptar la contraseña 
    hash_seguro = generate_password_hash(contrasena_plana)

    # Consulta SQL UPDATE en lugar de INSERT
    sql = """
        UPDATE usuarios 
        SET password_hash = %s, rol = %s 
        WHERE correo = %s
    """
    valores = (hash_seguro, rol_usuario, correo_admin)

    cursor.execute(sql, valores)
    conexion.commit()
    
    # Verificar si realmente se actualizó algún registro
    if cursor.rowcount > 0:
        print(f"✅ Usuario '{correo_admin}' actualizado a Administrador con éxito.")
    else:
        print(f"⚠️ No se hicieron cambios. Revisa si el correo está bien escrito.")

except mysql.connector.Error as err:
    print(f"❌ Error de base de datos: {err}")
finally:
    if 'cursor' in locals():
        cursor.close()
    if 'conexion' in locals() and conexion.is_connected():
        conexion.close()